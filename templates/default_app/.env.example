# Environment Variables
# Copy this file to .env and fill in your values.
# xp::loadEnv() reads this automatically at startup.

PORT=8080
DEBUG=true

# JWT secret — change this before deploying!
JWT_SECRET=change-me-before-deploying

# Database (uncomment when ready)
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/mydb
